{
  "manifest_version": 3,
  "name": "LeetCode GitHub AI Sync",
  "version": "1.0",
  "description": "Automatically sync LeetCode solutions to GitHub with optional AI enhancement.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*",
        "https://leetcode.com/submissions/detail/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}